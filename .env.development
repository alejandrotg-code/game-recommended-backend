# ── Desarrollo ──────────────────────────────────────────────
# Este archivo se sube a Git. No poner secretos aquí.

# Entorno (development | production)
ENV=development

# Logging (DEBUG en dev, WARNING en prod)
LOG_LEVEL=DEBUG

# CORS — permite el frontend local de Vite
CORS_ORIGINS=http://localhost:5173

# Rate limit — permisivo para desarrollo
RATE_LIMIT=100
RATE_WINDOW=60

# Puerto del servidor (opcional, uvicorn lo usa si se pasa --port)
PORT=8000
